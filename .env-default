# FileEngine HTTP REST bridge — configuration template (copy to .env)
FILEENGINE_GRPC_HOST=localhost
FILEENGINE_GRPC_PORT=50051

FILEENGINE_LDAP_ENDPOINT=ldap://localhost:1389
FILEENGINE_LDAP_DOMAIN=dc=rationalboxes,dc=com
FILEENGINE_LDAP_BIND_DN=cn=admin,dc=rationalboxes,dc=com
FILEENGINE_LDAP_BIND_PASSWORD=CHANGEME
FILEENGINE_LDAP_TENANT_BASE=ou=tenants,dc=rationalboxes,dc=com
FILEENGINE_LDAP_USER_BASE=ou=users,dc=rationalboxes,dc=com

HTTP_HOST=0.0.0.0
HTTP_PORT=8090
HTTP_THREAD_POOL=16

LOG_LEVEL=info
LOG_TO_CONSOLE=true

# Hardening
HTTP_MAX_BODY_BYTES=104857600
HTTP_CORS_ORIGIN=

# OAuth2 / OIDC login (BFF). Leave OAUTH_REDIRECT_BASE empty to disable.
# See OAUTH_SETUP.md for per-provider registration steps.
#   OAUTH_REDIRECT_BASE   public base URL of THIS bridge; the callback registered
#                         with each IdP is <base>/v1/auth/oauth/<provider>/callback
#   OAUTH_RETURN_ALLOWLIST  CSV of allowed SPA return-URL prefixes (anti open-redirect)
#   OAUTH_PROVIDERS       CSV of enabled providers (each needs an OAUTH_<NAME>_* block)
#   OAUTH_STATE_TTL_SECONDS  pending-authorization lifetime (default 300)
OAUTH_REDIRECT_BASE=
OAUTH_RETURN_ALLOWLIST=http://localhost:3000/
OAUTH_STATE_TTL_SECONDS=300
OAUTH_PROVIDERS=

# Per-provider config. KIND is "oidc" (default) or "github".
# OAUTH_GOOGLE_KIND=oidc
# OAUTH_GOOGLE_CLIENT_ID=
# OAUTH_GOOGLE_CLIENT_SECRET=
# OAUTH_GOOGLE_AUTH_URL=https://accounts.google.com/o/oauth2/v2/auth
# OAUTH_GOOGLE_TOKEN_URL=https://oauth2.googleapis.com/token
# OAUTH_GOOGLE_USERINFO_URL=https://openidconnect.googleapis.com/v1/userinfo
# OAUTH_GOOGLE_SCOPES=openid email profile
#
# OAUTH_GITHUB_KIND=github
# OAUTH_GITHUB_CLIENT_ID=
# OAUTH_GITHUB_CLIENT_SECRET=
# OAUTH_GITHUB_AUTH_URL=https://github.com/login/oauth/authorize
# OAUTH_GITHUB_TOKEN_URL=https://github.com/login/oauth/access_token
# OAUTH_GITHUB_USERINFO_URL=https://api.github.com/user
# OAUTH_GITHUB_EMAILS_URL=https://api.github.com/user/emails
# OAUTH_GITHUB_SCOPES=read:user user:email
