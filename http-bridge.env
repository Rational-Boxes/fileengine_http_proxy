# FileEngine HTTP Bridge configuration.
# Loaded by the systemd unit via EnvironmentFile=. Format: KEY=VALUE (no quotes,
# no inline comments). Edit and `systemctl restart fileengine-http-bridge`.

# --- HTTP listener ---
HTTP_HOST=0.0.0.0
HTTP_PORT=8090
# Dedicated, correctly-sized worker pool (concurrent long-lived transfers).
HTTP_THREAD_POOL=16
# Dedicated reporter listener for /healthz /readyz /poolz (one worker held back).
HTTP_MONITORING_PORT=8091
HTTP_MAX_BODY_BYTES=104857600
# Scoped CORS origin for browser clients (empty = CORS disabled). Never use *.
HTTP_CORS_ORIGIN=

# --- FileEngine gRPC core ---
FILEENGINE_GRPC_HOST=localhost
FILEENGINE_GRPC_PORT=50051

# --- LDAP authentication ---
FILEENGINE_LDAP_ENDPOINT=ldap://localhost:389
FILEENGINE_LDAP_DOMAIN=dc=example,dc=com
FILEENGINE_LDAP_BIND_DN=cn=admin,dc=example,dc=com
# REQUIRED: set the bind-account password (kept out of the package on purpose).
FILEENGINE_LDAP_BIND_PASSWORD=
FILEENGINE_LDAP_TENANT_BASE=ou=tenants,dc=example,dc=com
FILEENGINE_LDAP_USER_BASE=ou=users,dc=example,dc=com

# --- Bearer tokens ---
TOKEN_TTL_SECONDS=3600

# --- OAuth2 (optional; leave OAUTH_PROVIDERS empty to disable) ---
# Comma-separated provider ids; each needs OAUTH_<ID>_* settings (see DEVELOPER.md / OAUTH_SETUP.md).
OAUTH_PROVIDERS=
OAUTH_REDIRECT_BASE=
OAUTH_RETURN_ALLOWLIST=
OAUTH_STATE_TTL_SECONDS=300

# --- Logging ---
LOG_LEVEL=info
LOG_WRITE_TO_CONSOLE=true
