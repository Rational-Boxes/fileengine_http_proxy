# http_bridge configuration. Copy to `.env` and fill in the secrets. Values here
# are the local-dev defaults; the bridge reads this file from its working dir.

# gRPC core (the trusted-upstream backend the bridge proxies to).
FILEENGINE_GRPC_HOST=localhost
FILEENGINE_GRPC_PORT=50051

# OpenLDAP configuration (the bridge authenticates logins against this).
FILEENGINE_LDAP_ENDPOINT=ldap://localhost:1389
FILEENGINE_LDAP_DOMAIN=dc=rationalboxes,dc=com
FILEENGINE_LDAP_BIND_DN=cn=admin,dc=rationalboxes,dc=com
FILEENGINE_LDAP_BIND_PASSWORD=admin
FILEENGINE_LDAP_TENANT_BASE=ou=tenants,dc=rationalboxes,dc=com
FILEENGINE_LDAP_USER_BASE=ou=users,dc=rationalboxes,dc=com

LOG_LEVEL=debug
LOG_FILE=./log/webdav.log
LOG_WRITE_TO_CONSOLE=true

# PostgreSQL Configuration
FILEENGINE_PG_HOST=localhost
FILEENGINE_PG_PORT=5434
FILEENGINE_PG_DATABASE=fileengine_webdav
FILEENGINE_PG_USER=postgres
FILEENGINE_PG_PASSWORD=postgres

WEBDAV_HOST=0.0.0.0
WEBDAV_PORT=8088
# HTTP REST bridge
HTTP_HOST=0.0.0.0
HTTP_PORT=8090
HTTP_THREAD_POOL=16
# Max declared request-body size accepted by the bridge. Uploads stream to the
# core in chunks (never fully buffered), so this is a policy ceiling, not a
# memory limit. Default 100 MiB; raise if you need to accept larger single PUTs.
HTTP_MAX_BODY_BYTES=104857600
HTTP_CORS_ORIGIN=http://localhost:3000
# HS256 secret used to sign session JWTs. Generate a random value (e.g.
# `openssl rand -hex 32`) and keep it IDENTICAL to audit_service's
# FILEENGINE_JWT_SECRET so the audit read API can verify bridge-issued tokens.
FILEENGINE_JWT_SECRET=

# Durable audit emission — logs auth events (login_success / login_failure) to
# the shared Redis audit stream, drained by audit_service into the security log.
# Must be enabled or logins are never audited. The login-SUCCESS path is
# fail-closed on audit: if Redis is unreachable, successful logins 503 with
# "audit log unavailable" — so the Redis settings below must be correct.
FILEENGINE_AUDIT_ENABLED=true
FILEENGINE_REDIS_HOST=localhost
FILEENGINE_REDIS_PORT=6379
# The shared broker requires auth. Dev value is `password1`; must match the core
# and audit_service. An empty/wrong password makes audit publishes fail.
FILEENGINE_REDIS_PASSWORD=
FILEENGINE_AUDIT_STREAM=fileengine:audit
